@page "/profile/change-password"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject IHxMessengerService Messenger

<PageTitle>Change Password – XLDent</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <p>Redirecting...</p>
}
else
{
    <div class="d-flex align-items-center mb-4 gap-2">
        <HxButton Icon="BootstrapIcon.ArrowLeft" Color="ThemeColor.None" CssClass="p-0"
                  OnClick="@(() => Nav.NavigateTo("/profile"))" />
        <h4 class="mb-0">Change Password</h4>
    </div>

    <div style="max-width: 480px;">
        <HxCard>
            <BodyTemplate>
                <EditForm Model="_model" OnValidSubmit="Save">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Current Password</label>
                        <InputText type="password" class="form-control" @bind-Value="_model.CurrentPassword" />
                        <ValidationMessage For="@(() => _model.CurrentPassword)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <InputText type="password" class="form-control" @bind-Value="_model.NewPassword" />
                        <ValidationMessage For="@(() => _model.NewPassword)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm New Password</label>
                        <InputText type="password" class="form-control" @bind-Value="_model.NewPasswordConfirm" />
                        <ValidationMessage For="@(() => _model.NewPasswordConfirm)" />
                    </div>
                    @if (_error is not null)
                    {
                        <HxAlert Color="ThemeColor.Danger" CssClass="py-2">@_error</HxAlert>
                    }
                    <HxSubmit Text="Change Password" Color="ThemeColor.Primary" />
                </EditForm>
            </BodyTemplate>
        </HxCard>
    </div>
}

@code {
    PwModel _model = new();
    string? _error;

    protected override void OnInitialized()
    {
        if (!Auth.IsAuthenticated)
            Nav.NavigateTo("/");
    }

    async Task Save()
    {
        _error = null;
        try
        {
            await Api.ChangePasswordAsync(_model.CurrentPassword, _model.NewPassword, _model.NewPasswordConfirm);
            Messenger.AddInformation(title: null, message: "Password changed successfully.");
            Nav.NavigateTo("/profile");
        }
        catch (Refit.ApiException ex)
        {
            var body = await ex.GetContentAsAsync<ErrorBody>();
            _error = body?.Message ?? "Failed to change password.";
        }
    }

    class PwModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string CurrentPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string NewPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string NewPasswordConfirm { get; set; } = "";
    }

    record ErrorBody(string Message);
}
