@page "/"
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Dashboard – XLDent</PageTitle>

@if (!Auth.IsAuthenticated)
{
    <p>Redirecting to login...</p>
}
else
{
    <h4 class="mb-4">Agent Dashboard</h4>

    @if (_loadError is not null)
    {
        <HxAlert Color="ThemeColor.Danger" CssClass="mb-4">@_loadError</HxAlert>
    }

    <AgentKeyManager />

    @if (_agents.Count == 0)
    {
        <div class="text-muted fst-italic">No agents connected.</div>
    }

    @foreach (var agent in _agents)
    {
        <AgentCard AgentId="@agent" />
    }
}

@code {
    List<string> _agents    = [];
    string?      _loadError;

    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await Refresh();
        StartPolling();
    }

    async Task Refresh()
    {
        _loadError = null;
        try
        {
            _agents = await Api.GetAgentsAsync();
        }
        catch (HttpRequestException)
        {
            _loadError = "Cannot reach the API server. Make sure the API is running.";
        }
    }

    void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    await timer.WaitForNextTickAsync(ct);
                    var latest = await Api.GetAgentsAsync();
                    if (!latest.SequenceEqual(_agents))
                    {
                        _agents = latest;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch (OperationCanceledException) { break; }
                catch { /* silently ignore poll errors */ }
            }
        }, ct);
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
