@page "/register"
@inject ApiService Api
@inject NavigationManager Nav

<div style="max-width: 360px; margin: 4rem auto;">
    <HxCard>
        <HeaderTemplate>
            <strong>Create Account</strong>
        </HeaderTemplate>
        <BodyTemplate>
            <HxInputText Label="Email" @bind-Value="_email" Type="InputType.Email" />
            <HxInputText Label="Password" @bind-Value="_password" Type="InputType.Password" />
            <HxInputText Label="Confirm Password" @bind-Value="_confirm" Type="InputType.Password" />

            @if (_error is not null)
            {
                <HxAlert Color="ThemeColor.Danger" CssClass="mt-2">@_error</HxAlert>
            }

            @if (_success)
            {
                @if (_isActive)
                {
                    <HxAlert Color="ThemeColor.Success" CssClass="mt-2">
                        Account created. <a href="/login">Sign in</a>
                    </HxAlert>
                }
                else
                {
                    <HxAlert Color="ThemeColor.Info" CssClass="mt-2">
                        Account created. An administrator must activate your account before you can sign in.
                    </HxAlert>
                }
            }

            <div class="mt-3">
                <HxButton Text="Register" Color="ThemeColor.Primary" OnClick="Submit" Enabled="@(!_busy || _success)" />
            </div>
        </BodyTemplate>
    </HxCard>
</div>

@code {
    string _email = "", _password = "", _confirm = "";
    string? _error;
    bool _busy, _success, _isActive;

    async Task Submit()
    {
        _error = null;
        if (_password != _confirm)
        {
            _error = "Passwords do not match.";
            return;
        }
        _busy = true;
        try
        {
            var (success, isActive, error) = await Api.RegisterAsync(_email, _password, _confirm);
            if (success)
            {
                _success = true;
                _isActive = isActive;
            }
            else
            {
                _error = error;
            }
        }
        finally { _busy = false; }
    }
}
