@using Shared.Appointments
@using Shared.Messages.Requests
@inject ApiService Api

<HxCard CssClass="mb-4">
    <HeaderTemplate>
        <div class="d-flex align-items-center gap-3">
            <strong>Agent: @AgentId</strong>
            @if (_health is not null)
            {
                var (badgeColor, icon) = _health.Status switch
                {
                    AgentStatus.Online   => ("success",   BootstrapIcon.CheckCircleFill),
                    AgentStatus.Degraded => ("warning",   BootstrapIcon.ExclamationTriangleFill),
                    _                    => ("secondary", BootstrapIcon.XCircleFill)
                };
                <span class="badge bg-@badgeColor"><HxIcon Icon="@icon" /> @_health.Status</span>
                <span class="text-muted small">DB: @(_health.DbConnected ? "Connected" : "Disconnected")</span>
                @if (!string.IsNullOrWhiteSpace(_health.Version))
                {
                    <span class="text-muted small">v@(_health.Version)</span>
                }
                @if (_health.UpdatedAt.HasValue)
                {
                    <span class="text-muted small">Updated: @_health.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                }
                @if (_health.StartedAt.HasValue)
                {
                    <span class="text-muted small">Started: @_health.StartedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                }
                @if (_health.LastSeen.HasValue)
                {
                    <span class="text-muted small">Last seen: @_health.LastSeen.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                }
            }
            <HxButton Text="Check Health" Color="ThemeColor.Secondary"
                      Size="ButtonSize.Small" OnClick="CheckHealth"
                      Spinner="@_checkingHealth" />
        </div>
    </HeaderTemplate>
    <BodyTemplate>
        <h6 class="mb-2">Search Appointments</h6>
        <div class="row g-2 mb-2">
            <div class="col-sm-6 col-md-3">
                <HxInputText Label="Name" @bind-Value="_search.Name" Placeholder="Smith" />
            </div>
            <div class="col-sm-6 col-md-3">
                <HxInputText Label="Phone" @bind-Value="_search.Phone" Placeholder="4141234567" />
            </div>
            <div class="col-sm-6 col-md-3">
                <HxInputText Label="Email" @bind-Value="_search.Email" Placeholder="patient@example.com" />
            </div>
            <div class="col-sm-6 col-md-3">
                <HxInputText Label="Event ID" @bind-Value="_search.EventId" Placeholder="UUID" />
            </div>
        </div>
        <div class="mb-3">
            <HxButton Text="Search" Color="ThemeColor.Primary"
                      Size="ButtonSize.Small" OnClick="RunSearch"
                      Spinner="@_searching" />
        </div>

        @if (_error is not null)
        {
            <HxAlert Color="ThemeColor.Danger" CssClass="mt-2">@_error</HxAlert>
        }

        @{
            var allAppts = _results
                ?.SelectMany(p => p.Appointments.Select(a => (Patient: p, Appt: a)))
                .OrderByDescending(x => x.Appt.StartDate ?? DateTime.MinValue)
                .ThenByDescending(x => x.Appt.StartTime ?? TimeSpan.Zero)
                .ToList();
        }

        @if (allAppts is { Count: > 0 })
        {
            <div class="table-responsive mt-2">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Patient</th>
                            <th>Provider</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Duration</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (patient, appt) in allAppts)
                        {
                            <tr>
                                <td class="text-nowrap">@(appt.StartDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td class="text-nowrap">
                                    @if (appt.StartTime.HasValue)
                                    { @($"{appt.StartTime.Value:hh\\:mm}") }
                                    else { <span>—</span> }
                                </td>
                                <td>
                                    <span class="fw-semibold">@patient.FullName</span>
                                    @if (!string.IsNullOrWhiteSpace(patient.MobilePhone ?? patient.HomePhone))
                                    {
                                        <br /><span class="text-muted small">@(patient.MobilePhone ?? patient.HomePhone)</span>
                                    }
                                </td>
                                <td>@(appt.ProviderName ?? "—")</td>
                                <td>@(appt.Reason ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(appt.Status))
                                    {
                                        var sc = appt.Status.ToLower() switch
                                        {
                                            "cancelled" or "canceled" => "secondary",
                                            "confirmed"               => "success",
                                            _                         => "light text-dark border"
                                        };
                                        <span class="badge bg-@sc">@appt.Status</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>@(appt.Duration ?? "—")</td>
                                <td class="text-end">
                                    @{
                                        var apptDateTime = appt.StartDate.HasValue
                                            ? appt.StartDate.Value.Date + (appt.StartTime ?? TimeSpan.Zero)
                                            : (DateTime?)null;
                                        var isPast = apptDateTime.HasValue && apptDateTime.Value < DateTime.Now;
                                    }
                                    @if (!isPast)
                                    {
                                        <HxButton Text="Cancel" Color="ThemeColor.Danger"
                                                  Size="ButtonSize.Small"
                                                  Spinner="@(_cancelling.Contains(appt.EventId))"
                                                  OnClick="@(() => RunCancel(appt.EventId))" />
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (allAppts is { Count: 0 })
        {
            <p class="text-muted small mt-2">No appointments found.</p>
        }
    </BodyTemplate>
</HxCard>

@code {
    [Parameter, EditorRequired] public string AgentId { get; set; } = string.Empty;

    AgentHealthResponse?            _health;
    List<PatientAppointmentResult>? _results;
    string?                         _error;
    bool                            _searching;
    bool                            _checkingHealth;

    readonly SearchAppointmentsRequest _search     = new();
    readonly HashSet<string>           _cancelling = [];

    async Task RunSearch()
    {
        _error   = null;
        _results = null;
        _searching = true;
        StateHasChanged();
        try
        {
            _results = await Api.SearchAppointmentsAsync(AgentId, _search);
        }
        catch (Refit.ApiException ex)
        {
            _error = $"Search failed: {(int)ex.StatusCode} {ex.ReasonPhrase}";
        }
        catch (Exception ex)
        {
            _error = $"Search failed: {ex.Message}";
        }
        finally
        {
            _searching = false;
        }
    }

    async Task RunCancel(string eventId)
    {
        _cancelling.Add(eventId);
        StateHasChanged();
        try
        {
            await Api.CancelAppointmentAsync(AgentId, eventId);
        }
        catch (Refit.ApiException ex)
        {
            _error = $"Cancel failed: {(int)ex.StatusCode} {ex.ReasonPhrase}";
            _cancelling.Remove(eventId);
            return;
        }
        catch (Exception ex)
        {
            _error = $"Cancel failed: {ex.Message}";
            _cancelling.Remove(eventId);
            return;
        }
        _cancelling.Remove(eventId);
        await RunSearch();
    }

    async Task CheckHealth()
    {
        _checkingHealth = true;
        StateHasChanged();
        try
        {
            _health = await Api.GetAgentHealthAsync(AgentId);
        }
        catch (Refit.ApiException ex)
        {
            _error = $"Health check failed: {(int)ex.StatusCode} {ex.ReasonPhrase}";
        }
        catch (Exception ex)
        {
            _error = $"Health check failed: {ex.Message}";
        }
        finally
        {
            _checkingHealth = false;
        }
    }
}
